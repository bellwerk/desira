# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Optional email notifications (Resend)
# Notifications still work in-app without these values.
RESEND_API_KEY=your_resend_api_key
NOTIFICATION_FROM_EMAIL="Desira <notifications@example.com>"

# Optional centralized error tracking webhook
ERROR_TRACKING_WEBHOOK_URL=
# Optional production ops alert webhook (sent only when NODE_ENV=production)
OPS_ALERT_WEBHOOK_URL=

# Optional bug-report webhook
BUG_REPORT_WEBHOOK_URL=

# Site URL (required for OAuth redirects; use production URL in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Skimlinks (Affiliate monetization)
# Get your publisher ID from https://www.skimlinks.com/
SKIMLINKS_PUBLISHER_ID=your_skimlinks_publisher_id
# App URL (set to production domain in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Amazon Product Advertising API (for reliable Amazon link previews)
# Requires Amazon Associates access + PA-API credentials.
AMAZON_PAAPI_ACCESS_KEY=your_amazon_paapi_access_key
AMAZON_PAAPI_SECRET_KEY=your_amazon_paapi_secret_key
AMAZON_PAAPI_PARTNER_TAG=your_amazon_associates_partner_tag
# Optional explicit Amazon Associates tag for outbound /api/go redirects.
# If omitted, AMAZON_PAAPI_PARTNER_TAG is used.
AMAZON_ASSOCIATES_TAG=your_amazon_associates_partner_tag

# Development only - enables /api/seed endpoint (NEVER set in production)
# ALLOW_SEED=true
