{
  "name": "desira",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "prebuild:cloudflare": "node scripts/patch-opennext-windows.mjs",
    "build:cloudflare": "pnpm -s prebuild:cloudflare && opennextjs-cloudflare build",
    "start": "next start",
    "test": "pnpm -s e2e",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install chromium",
    "preview": "pnpm -s build:cloudflare && opennextjs-cloudflare preview",
    "deploy": "pnpm -s build:cloudflare && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@stripe/react-stripe-js": "^5.4.1",
    "@stripe/stripe-js": "^8.6.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.89.0",
    "next": "16.1.6",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^20.1.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "supabase": "^2.78.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.73.0"
  },
  "packageManager": "pnpm@10.26.2",
  "pnpm": {
    "overrides": {
      "qs": "6.15.0",
      "tar": "7.5.11",
      "minimatch@3": "3.1.5",
      "minimatch@9": "9.0.7",
      "glob@12>minimatch": "10.2.4",
      "ajv": "6.14.0",
      "flatted": "3.4.1",
      "@smithy/config-resolver": ">=4.4.0",
      "fast-xml-parser": "5.5.5",
      "undici": "7.24.1"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "supabase"
    ]
  }
}
